<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Light green background -->
    <solid android:color="#D7EFE5"/>

    <!-- Rounded pill shape -->
    <corners android:radius="50dp"/>

    <!-- Optional subtle border -->
    <stroke
        android:width="1dp"
        android:color="#C5E5D6"/>

    <!-- Padding inside chip -->
    <padding
        android:left="16dp"
        android:right="16dp"
        android:top="8dp"
        android:bottom="8dp"/>

</shape>