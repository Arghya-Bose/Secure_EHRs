<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#D6FCEC">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:gravity="right"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/edit_profile"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/edit_profile"/>
    </LinearLayout>

    <!-- SCROLL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- PROFILE -->
            <FrameLayout
                android:id="@+id/profileContainer"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/profileImg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/profile"
                    app:civ_border_width="3dp"
                    app:civ_border_color="#1BAA6F"/>

                <ImageView
                    android:id="@+id/pic_image_toProfile"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="6dp"
                    android:src="@drawable/ic_camera"
                    android:background="@drawable/circle_white_bg"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alex Chen"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#003A2C"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/joining_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Member since Jan 2023"
                android:textColor="#326957"
                android:layout_gravity="center"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_quick_item_profile"
                android:padding="16dp">

                <TextView
                    android:drawableStart="@drawable/personalinfo"
                    android:text="Personal Info"
                    android:textColor="#003A2C"
                    android:textSize="16sp"
                    android:drawablePadding="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:id="@+id/viewProfileDetail"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    android:background="@drawable/white_rounded_box"
                    android:padding="12dp">

                    <TextView
                        android:textColor="#5A8F76"
                        android:layout_width="wrap_content"
                        android:textSize="12sp"
                        android:paddingLeft="10dp"
                        android:paddingBottom="10dp"
                        android:layout_height="wrap_content"
                        android:text="EMAIL"/>

                    <TextView
                        android:id="@+id/tvEmail"
                        android:textColor="#003A2C"
                        android:paddingLeft="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="alex.chen@healthlock.io"/>

                    <TextView
                        android:layout_gravity="right"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See more.."/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:background="@drawable/white_rounded_box"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:elevation="2dp">

                    <!-- LEFT SIDE -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UID"
                            android:paddingLeft="10dp"
                            android:textSize="12sp"
                            android:textColor="#5A8F76"
                            android:paddingBottom="10dp"/>

                        <TextView
                            android:id="@+id/tvUniqueId"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="UID_123456"
                            android:textColor="#003A2C"
                            android:paddingLeft="10dp"
                            android:textSize="14sp"
                            android:maxLines="1"
                            android:ellipsize="end"/>
                    </LinearLayout>

                    <!-- RIGHT BUTTON -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyUid"
                        android:layout_width="90dp"
                        android:layout_height="40dp"
                        android:text="Copy"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#1BAA6F"
                        app:cornerRadius="20dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/qr_code_tv"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    android:background="@drawable/white_rounded_box"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QR"
                        android:paddingLeft="10dp"
                        android:textSize="12sp"
                        android:textColor="#5A8F76"
                        android:paddingBottom="10dp"/>

                    <TextView
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:text="Click to get QR Code"
                        android:paddingLeft="10dp"
                        android:textColor="#003A2C"
                        android:textSize="14sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        />
                </LinearLayout>

            </LinearLayout>

            <!-- ================= HEALTH PROFILE ================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_quick_item_profile"
                android:padding="16dp">

                <TextView
                    android:textColor="#003A2C"
                    android:textSize="16sp"
                    android:drawablePadding="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:drawableStart="@drawable/heart"
                    android:text="Health Profile" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:paddingLeft="10dp"
                    android:background="@drawable/white_rounded_box"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:textColor="#003A2C"
                    android:text="Blood Type: A+"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/white_rounded_box"
                    android:gravity="center_vertical"
                    android:textColor="#003A2C"
                    android:padding="12dp"
                    android:text="Allergies: Penicillin, Peanuts"/>

            </LinearLayout>

            <!-- ================= ACCOUNT SECURITY ================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_quick_item_profile"
                android:padding="16dp">

                <TextView
                    android:drawableStart="@drawable/security_sld"
                    android:text="Account Security"
                    android:textColor="#003A2C"
                    android:textSize="16sp"
                    android:drawablePadding="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/white_rounded_box"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textColor="#003A2C"
                        android:layout_weight="1"
                        android:text="2-Step Verification"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ================= APP SETTINGS ================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_quick_item_profile"
                android:padding="16dp">

                <TextView
                    android:text="App Settings"
                    android:textStyle="bold"
                    android:drawableStart="@drawable/ic_settings_profile"
                    android:textColor="#003A2C"
                    android:textSize="16sp"
                    android:drawablePadding="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/white_rounded_box"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:textColor="#003A2C"
                    android:text="Notifications: On"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/white_rounded_box"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:textColor="#003A2C"
                    android:text="Theme: Light"/>
            </LinearLayout>

            <!-- LOGOUT -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/logout_profile"
                android:layout_marginTop="30dp"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Log Out"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="#D32F2F"
                app:icon="@drawable/logout_arrow"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#D32F2F"
                android:backgroundTint="@android:color/white"
                app:strokeColor="#FFCDD2"
                app:strokeWidth="1dp"
                app:cornerRadius="20dp"/>
        </LinearLayout>
    </ScrollView>

</LinearLayout>