<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".MainActivity">

    <!-- ================= MAIN CONTENT ================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- TOP BAR -->
        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:background="@color/gray"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="10dp"
                android:src="@drawable/ic_menu"
                android:tint="@color/white" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <de.hdodenhof.circleimageview.CircleImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/profile"
                android:id="@+id/profile"
                app:civ_border_width="2dp"
                app:civ_border_color="@color/gray_light" />
        </LinearLayout>

        <!-- SCROLL CONTENT -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/top_bar"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="@drawable/rounded_card"
                    android:backgroundTint="#C1E9B8"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/doc_image"
                        android:layout_width="120dp"
                        android:layout_height="match_parent"
                        android:background="#C1E9B8"
                        android:src="@drawable/logomain" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_toEndOf="@id/doc_image"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Welcome To World Most \nSecure Plartform"
                            android:textColor="#000000"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btn_about"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:backgroundTint="#7CFF7C"
                            android:text="About App"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            android:textColor="#2E7D32" />
                    </LinearLayout>
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="12dp"
                    android:text="Heal Yourself With Scanning Image"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="@drawable/rounded_card"
                    android:backgroundTint="#F0F0FB"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- ROW: 3 ITEMS -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <!-- ITEM 1 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:src="@drawable/scanb"
                                android:scaleType="fitCenter" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Use AI"
                                android:textSize="12sp"
                                android:textColor="#000000" />
                        </LinearLayout>

                        <!-- ITEM 2 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:src="@drawable/scana"
                                android:scaleType="fitCenter" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Detect"
                                android:textSize="12sp"
                                android:textColor="#000000" />
                        </LinearLayout>

                        <!-- ITEM 3 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:src="@drawable/scanc"
                                android:scaleType="fitCenter" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Result"
                                android:textSize="12sp"
                                android:textColor="#000000" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- BUTTON -->
                    <Button
                        android:id="@+id/scan_btn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="#7CFF7C"
                        android:text="Scan Your Image"
                        android:textColor="#2E7D32" />

                </LinearLayout>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="12dp"
                    android:text="For Your Reference"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:layout_marginTop="8dp">

                    <!-- Card 1 : View Report -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card1"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#E6E86C"
                        app:rippleColor="?attr/colorControlHighlight">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <!-- NEW ImageView (background / decoration) -->
                            <ImageView
                                android:id="@+id/bgIcon"
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:visibility="gone"
                                android:src="@drawable/your_background_image"
                                android:scaleType="centerCrop"
                                android:layout_gravity="right"
                                android:layout_margin="5dp"
                                android:alpha="0.15" />

                            <!-- Center content -->
                            <LinearLayout
                                android:id="@+id/option_layout_1"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                android:orientation="vertical">

                                <!-- Eye icon stays in middle -->
                                <ImageView
                                    android:layout_width="55dp"
                                    android:layout_height="55dp"
                                    android:src="@drawable/eyes_img" />

                                <TextView
                                    android:layout_marginTop="8dp"
                                    android:text="@string/view_your_report"
                                    android:textStyle="bold"
                                    android:textColor="#000"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" />
                            </LinearLayout>

                        </FrameLayout>

                    </com.google.android.material.card.MaterialCardView>


                    <!-- Card 2 : Upload Report -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card2"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#7FE0E6"
                        app:rippleColor="?attr/colorControlHighlight">

                        <LinearLayout
                            android:id="@+id/option_layout_2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="50dp"
                                android:layout_height="47dp"
                                android:src="@drawable/upload_img" />

                            <TextView
                                android:layout_marginTop="8dp"
                                android:text="@string/upload_report"
                                android:textStyle="bold"
                                android:textColor="#000" android:layout_height="wrap_content" android:layout_width="wrap_content"/>
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card 3 : Case Study -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card3"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#F3A1F3"
                        app:rippleColor="?attr/colorControlHighlight">

                        <LinearLayout
                            android:id="@+id/option_layout_3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:src="@drawable/ic_launcher_background" />

                            <TextView
                                android:layout_marginTop="8dp"
                                android:text="Case Study"
                                android:textStyle="bold"
                                android:textColor="#000" android:layout_height="wrap_content" android:layout_width="wrap_content"/>
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card 4 : Report -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card4"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#E68186"
                        app:rippleColor="?attr/colorControlHighlight">

                        <LinearLayout
                            android:id="@+id/option_layout_4"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="55dp"
                                android:layout_height="55dp"
                                android:src="@drawable/chat_icon" />

                            <TextView
                                android:layout_marginTop="8dp"
                                android:text="Health Assistant"
                                android:textStyle="bold"
                                android:textColor="#000" android:layout_height="wrap_content" android:layout_width="wrap_content"/>
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </GridLayout>


                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Our Assets &amp; Our Team"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="12dp" />

                <!-- CARD 1 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/historyCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#7CFF7C">

                    <LinearLayout
                        android:id="@+id/medical_history_view"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:orientation="horizontal"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/medicalhistory"
                            android:contentDescription="Assets" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:text="Medical History"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_arrow_right"
                            android:contentDescription="Arrow" />
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- CARD 2 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#7CFF7C">

                    <LinearLayout
                        android:id="@+id/report_analysis_view"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/scanc"
                            android:contentDescription="Development Team" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:text="Application Development Team"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_arrow_right"
                            android:contentDescription="Arrow" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#7CF08A">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/scanc"
                            android:contentDescription="Development Team" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:text="Application Development Team"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_arrow_right"
                            android:contentDescription="Arrow" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ================= LEFT NAVIGATION DRAWER ================= -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/left_profile"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/profile"
            app:civ_border_width="2dp"
            app:civ_border_color="@color/gray"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/name_text"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp" android:layout_height="wrap_content" android:layout_width="wrap_content"/>

        <!-- MENU ITEMS -->
        <TextView
            android:id="@+id/dashboard"
            android:text="Dashboard"
            android:textSize="16sp"
            android:padding="12dp"  android:layout_height="wrap_content" android:layout_width="wrap_content"/>

        <TextView
            android:id="@+id/profile_viewers"
            android:text="Profile"
            android:textSize="16sp"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:padding="12dp" />

        <TextView
            android:text="Settings"
            android:textSize="16sp"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:padding="12dp" />

        <TextView
            android:id="@+id/btn_loout"
            android:text="Logout"
            android:textSize="16sp"
            android:padding="12dp"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:textColor="@color/red" />

    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>