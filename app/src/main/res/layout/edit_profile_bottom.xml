<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="@drawable/rounded_handle"
        android:layout_marginBottom="16dp" />

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:src="@drawable/logomain" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/etAge"
                android:hint="Age"
                android:inputType="number"
                android:layout_width="match_parent"
                android:background="@drawable/search_background_1"
                android:layout_height="45dp"
                android:layout_marginBottom="15dp"
                android:padding="10dp"/>

            <EditText
                android:id="@+id/etDob"
                android:hint="DOB (DD/MM/YYYY)"
                android:layout_width="match_parent"
                android:background="@drawable/search_background_1"
                android:layout_height="45dp"
                android:layout_marginBottom="15dp"
                android:padding="10dp"/>

            <EditText
                android:id="@+id/etGender"
                android:hint="Gender"
                android:layout_width="match_parent"
                android:background="@drawable/search_background_1"
                android:layout_height="45dp"
                android:layout_marginBottom="15dp"
                android:padding="10dp"/>

            <EditText
                android:id="@+id/etBloodGroup"
                android:hint="Blood Group"
                android:layout_width="match_parent"
                android:background="@drawable/search_background_1"
                android:layout_height="45dp"
                android:layout_marginBottom="15dp"
                android:padding="10dp"/>

            <EditText
                android:id="@+id/etContact"
                android:hint="Contact Details"
                android:layout_width="match_parent"
                android:background="@drawable/search_background_1"
                android:layout_height="45dp"
                android:layout_marginBottom="15dp"
                android:padding="10dp"/>

            <EditText
                android:id="@+id/etEmergency"
                android:hint="Emergency Contact"
                android:layout_width="match_parent"
                android:background="@drawable/search_background_1"
                android:layout_height="45dp"
                android:layout_marginBottom="15dp"
                android:padding="10dp"/>

            <Button
                android:id="@+id/btnSaveProfile"
                android:backgroundTint="#7CFF7C"
                android:textColor="#2E7D32"
                android:text="Save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </ScrollView>




</LinearLayout>