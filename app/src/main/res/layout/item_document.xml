<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fileCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="28dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#F3F7F5"
    app:rippleColor="#D7EFE5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- LEFT ICON CIRCLE -->
        <LinearLayout
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_icon_circle"
            android:gravity="center">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_file"
                android:tint="#0E6B4D"/>
        </LinearLayout>

        <!-- TEXT CONTENT -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <!-- TITLE -->
            <TextView
                android:id="@+id/fileNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Annual Physical Panel"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#003A2C"/>

            <!-- SUBTITLE -->
            <TextView
                android:id="@+id/feedbackText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Comprehensive blood work and metabolic profile"
                android:textSize="13sp"
                android:textColor="#326957"/>

            <!-- TAGS -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/uploadedByText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DR. SARAH MITCHELL"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D5B"
                    android:background="@drawable/bg_chip"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Security System Active"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D5B"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_chip"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"/>
            </LinearLayout>

            <!-- DATE -->
            <TextView
                android:id="@+id/dateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oct 14"
                android:textSize="13sp"
                android:textColor="#003A2C"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- RIGHT ARROW -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_right"
            android:tint="#8FBFA7"/>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>