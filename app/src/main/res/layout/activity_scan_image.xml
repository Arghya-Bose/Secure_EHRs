<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#D6FCEC">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btn_back_view"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="How To Use"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginStart="10dp"
            android:textColor="#003A2C"/>
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Steps to Upload Medical Records"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#003A2C"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. Login securely using password, OTP, or biometric authentication."
                        android:textSize="14sp"
                        android:textColor="#333333"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="2. Open the Medical Records section from dashboard."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="3. Select upload option: From device storage."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="4. Upload prescription, lab report, or health document."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="5. OCR extracts text and identifies medical parameters."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="6. Abnormal values are highlighted automatically."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="7. Record is encrypted and stored securely."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="8. View uploaded records anytime in medical history."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_marginTop="20dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SecureEHR App Guidelines"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#003A2C"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. Register/Login:\nCreate an account or login using your registered email and password. Biometric authentication can also be enabled for faster and secure access."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="2. Complete Profile:\nFill in personal details such as name, age, blood group, emergency contact, allergies, and medical history."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="3. Upload Medical Records:\nUpload prescriptions, reports, scans, and health documents from camera, gallery, or PDF files."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="4. OCR Lab Report Analysis:\nThe app scans lab reports using OCR and automatically extracts medical values. Abnormal values are highlighted for easier understanding."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="5. View Medical History:\nUsers can access previously uploaded reports, prescriptions, and health records anytime."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="6. Share Records Securely:\nGenerate QR codes to securely share medical records with doctors or healthcare providers."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="7. Prescription Management:\nStore and manage doctor prescriptions in one secure location."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="8. Security Features:\nAll records are protected using AES encryption, SHA-256 hashing, biometric login, role-based access control, and screenshot restrictions."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="9. Logout Safely:\nAlways logout after using shared devices to protect your medical information."
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>