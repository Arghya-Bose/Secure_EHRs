<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#D6FCEC">

    <!-- Center Content -->
    <LinearLayout
        android:id="@+id/centerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Logo Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardElevation="20dp"
            app:cardCornerRadius="35dp"
            android:outlineAmbientShadowColor="#80A8F5E5"
            android:outlineSpotShadowColor="#80A8F5E5">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="30dp"
                android:layout_marginLeft="5dp"
                android:layout_gravity="center"
                android:src="@drawable/logoprogress"/>
        </androidx.cardview.widget.CardView>

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SecureEHRs"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#003828"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ADVANCED SECURITY SYSTEM"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:textColor="#2D4D42"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- Bottom Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="30dp">

        <!-- Horizontal Progress -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="280dp"
            android:layout_height="8dp"
            android:layout_marginTop="40dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#00C781"
            android:progressBackgroundTint="#CFEDE3"/>

        <!-- Status Text -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ESTABLISHING SECURE LINK"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:textColor="#8B9E96"
            android:layout_marginTop="20dp"/>

        <!-- Security Badge -->
        <androidx.cardview.widget.CardView
            android:layout_width="300dp"
            android:layout_height="55dp"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="false"
            android:backgroundTint="#F4F8F6">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="@android:color/transparent">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_secure"
                    app:tint="#00A76F" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" SECURE &amp; ENCRYPTED BY AEGIS"
                    android:textStyle="bold"
                    android:textSize="10sp"
                    android:textColor="#2D4D42"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Retry Button -->
        <Button
            android:id="@+id/retryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Retry"
            android:visibility="gone"
            android:layout_marginTop="20dp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#16C784"/>
    </LinearLayout>

</RelativeLayout>