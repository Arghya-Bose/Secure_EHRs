<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#D6FCEC"
    tools:context="com.example.finalyearprojecta.CreateAccount">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">


        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Welcome Back"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:textColor="#003A2C"
            android:layout_marginTop="34dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Secure Clinical Workspace"
            android:textSize="14sp"
            android:layout_marginLeft="20dp"
            android:textColor="#326957" />

        <!-- MAIN LOGIN CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginEnd="22dp"
            android:layout_marginTop="50dp"
            android:layout_marginBottom="18dp"
            app:cardCornerRadius="36dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#E6FFED">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- CLINICAL ID -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email ID"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#326957"
                    android:layout_marginTop="20dp" />

                <EditText
                    android:id="@+id/edit_email_text"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:hint="e.g. yourid@gmail.com"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:drawableStart="@drawable/ic_person"
                    android:drawablePadding="12dp"
                    android:textSize="18sp"
                    android:textColor="#326957"
                    android:textColorHint="#326957"
                    android:background="@drawable/bg_light_green_round"
                    android:inputType="textEmailAddress" />

                <!-- PASSWORD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Password"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#326957" />

                    <TextView
                        android:id="@+id/forgot_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Forgot Access?"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#0A7A49" />
                </LinearLayout>

                <EditText
                    android:id="@+id/edit_password_text"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:hint="••••••••••"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:drawableStart="@drawable/lock_login"
                    android:drawablePadding="12dp"
                    android:textSize="18sp"
                    android:textColor="#326957"
                    android:textColorHint="#326957"
                    android:background="@drawable/bg_light_green_round"
                    android:inputType="textPassword" />

                <!-- ENCRYPTION BOX -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginTop="28dp"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/security_sld" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:text="END-TO-END&#10;ENCRYPTION"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#2D5E4A" />

                    <Switch
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- LOGIN BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/loginBtn"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="32dp"
                    android:text="Login"
                    android:textAllCaps="false"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#16A765"
                    app:cornerRadius="32dp" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="14dp"
                    android:visibility="gone" />

                <!-- FOOT TEXT -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account?"
                    android:textAlignment="center"
                    android:textSize="14sp"
                    android:textColor="#006D47"
                    android:layout_marginTop="32dp" />

                <TextView
                    android:id="@+id/createAccountTxtViewBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create Account"
                    android:textAlignment="center"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/red"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- BOTTOM LINKS -->


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2026 HealthLock Medical Editorial. Secure and Encrypted."
            android:textAlignment="center"
            android:textSize="15sp"
            android:textColor="#356654"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="28dp"
            android:paddingHorizontal="24dp" />

    </LinearLayout>

</ScrollView>